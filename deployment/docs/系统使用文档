9.2.2 本地存储
使用localStorage持久化关键数据：

// 保存患者数据到localStorage
function savePatientsToStorage() {
    localStorage.setItem('fracture_patients', JSON.stringify(appState.patients));
}

// 从localStorage加载患者数据
function loadPatientsFromStorage() {
    const saved = localStorage.getItem('fracture_patients');
    if (saved) {
        appState.patients = JSON.parse(saved);
    }
}
